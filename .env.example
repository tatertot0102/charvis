# Jarvis — environment template. Copy to .env and fill in. NEVER commit .env.

# App
APP_ENV=development          # development | production
BIND_PORT=8000               # host port the brain is published on
TZ=UTC                       # e.g. America/New_York

# Auth — every endpoint requires this bearer token, even over Tailscale.
# Generate one with:  make token
AUTH_SHARED_TOKEN=change-me-run-make-token

# Database (compose-internal host "db"; do not change unless you know why)
DB_DSN=postgresql+asyncpg://jarvis:jarvis@db:5432/jarvis

# --- LLM (provider-agnostic; switch providers by changing these only) ---
# Provider: ollama | openai | anthropic | lmstudio | echo
LOCAL_LLM_PROVIDER=ollama
# Base URL. For Ollama in Docker, host.docker.internal reaches the Mac host.
# Leave blank to use the provider's default.
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434
LOCAL_LLM_MODEL=llama3.2:3b
# Only needed if you select these cloud providers:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Telegram (bot is DISABLED until a token is set) ---
# Token from @BotFather:
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric Telegram user ids allowed to talk to the bot (empty = allow all).
# Get yours from @userinfobot.
TELEGRAM_ALLOWED_USER_IDS=

# --- Secrets at rest (Phase 2+) ---
# Fernet key that encrypts OAuth tokens in Postgres. Generate one with:  make secret-key
# Back it up — losing it means re-authing every integration.
SECRET_ENCRYPTION_KEY=

# --- Google (Phase 2A: Calendar; Phase 2B: Gmail — both read-only, one client) ---
# From Google Cloud Console (see EXTERNAL_ACTIONS.md §2). Leave blank until you complete that setup.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must EXACTLY match an Authorized redirect URI on the OAuth client (default assumes the brain is
# reachable at localhost:8000; change host/port to match how you open the consent flow).
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/integrations/google/callback

# --- Gmail read behavior (Phase 2B; sensible defaults — override only if needed) ---
GMAIL_UNREAD_MAX=20          # max messages returned by unread/today/search
GMAIL_SYNC_MAX_THREADS=25    # recent threads scanned per waiting-on sync (bounds API calls)
GMAIL_SYNC_WINDOW_DAYS=14    # how far back a sync looks
WAITING_FOLLOWUP_DAYS=4      # age after which "waiting on them" suggests a nudge

# --- Unified intelligence (Phase 2C; sensible defaults — override only if needed) ---
UPCOMING_WINDOW_DAYS=7        # how far ahead "next meeting" / upcoming events looks
DEADLINE_WINDOW_DAYS=14       # how far ahead deadlines are aggregated
EVENT_EMAIL_LOOKBACK_DAYS=30  # window for finding emails related to a calendar event
CONTEXT_MAX_RELATED_EMAILS=5  # cap on related emails pulled per event

# --- Memory / deep context (Phase 2C.5; consolidation over EXISTING data only, no new setup) ---
MEMORY_EMAIL_LOOKBACK_DAYS=180    # how far back the Gmail mirror is scanned (~6 months)
MEMORY_CALENDAR_BACK_DAYS=90      # long-range calendar lookback for consolidation
MEMORY_CALENDAR_FORWARD_DAYS=90   # long-range calendar lookahead for consolidation
MEMORY_CAPTURE_LIMIT=500          # max captures scanned per consolidation run
MEMORY_TELEGRAM_MESSAGE_LIMIT=500 # max chat messages scanned per consolidation run
