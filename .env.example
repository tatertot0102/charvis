# Jarvis — environment template. Copy to .env and fill in. NEVER commit .env.
# Phase 0 keys only. Later phases (Telegram, LLM, Google, Todoist) add their own keys.

# App
APP_ENV=development          # development | production
BIND_PORT=8000               # host port the brain is published on
TZ=UTC                       # e.g. America/New_York

# Auth — every endpoint requires this bearer token, even over Tailscale.
# Generate one with:  make token
AUTH_SHARED_TOKEN=change-me-run-make-token

# Database (compose-internal host "db"; do not change unless you know why)
DB_DSN=postgresql+asyncpg://jarvis:jarvis@db:5432/jarvis
